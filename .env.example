# Slack App設定（https://api.slack.com/apps で取得）
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Notion Integration設定（https://www.notion.so/profile/integrations で取得）
NOTION_API_KEY=ntn_your-notion-api-key
NOTION_DATABASE_ID=your-database-id-32-characters

# X (Twitter) API設定（https://developer.x.com で取得）
X_BEARER_TOKEN=your-x-bearer-token
X_USER_ID=your-x-user-id

# Anthropic API設定（https://console.anthropic.com で取得）
ANTHROPIC_API_KEY=your-anthropic-api-key

# X分析用Notionデータベース
NOTION_X_DATABASE_ID=your-x-analysis-database-id

# Vercel Cron認証（Vercelダッシュボードで設定）
CRON_SECRET=your-cron-secret
